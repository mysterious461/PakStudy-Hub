NODE_ENV=development
PORT=5000

# Firebase Admin / Google Cloud
FIREBASE_PROJECT_ID=pakstudy-hub-d418b
GOOGLE_CLOUD_PROJECT=pakstudy-hub-d418b
# Copy the exact bucket name from Firebase Console > Build > Storage.
# Common values are pakstudy-hub-d418b.appspot.com or pakstudy-hub-d418b.firebasestorage.app.
FIREBASE_STORAGE_BUCKET=pakstudy-hub-d418b.firebasestorage.app
# Either use Application Default Credentials or paste a service account JSON string:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Optional BigQuery event sink
BIGQUERY_ENABLED=false
BIGQUERY_DATASET=pakstudy_hub
BIGQUERY_EVENTS_TABLE=events

# Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENTS_CURRENCY=pkr
PAYMENTS_SUCCESS_URL=http://localhost:5000/profile?payment=success
PAYMENTS_CANCEL_URL=http://localhost:5000/profile?payment=cancelled

# Optional AI Tutor provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
